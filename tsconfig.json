{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": false,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "paths": {
      "@uniframe/adapters": ["packages/adapters/src/index.ts"],
      "@uniframe/adapters/*": ["packages/adapters/src/*"],
      "@uniframe/core": ["packages/core/src/index.ts"],
      "@uniframe/core/*": ["packages/core/src/*"],
      "@uniframe/vite": ["packages/vite/src/index.ts"],
      "@uniframe/vite/*": ["packages/vite/src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node", "react", "react-dom", "vite/client"]
  },
  "include": [
    "apps/**/*.js",
    "apps/**/*.jsx",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "apps/**/*.vue",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "examples/**/*.vue",
    "framework.config.js",
    "packages/**/*.js",
    "packages/**/*.ts",
    "tests/**/*.js",
    "tests/**/*.ts",
    "templates/**/*.ts",
    "types/**/*.d.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "**/dist"]
}
