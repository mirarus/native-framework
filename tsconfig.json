{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2023",
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "apps/**/*.js",
    "apps/**/*.jsx",
    "framework.config.js",
    "packages/**/*.js",
    "shared/**/*.js",
    "tests/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "**/dist"]
}
