{
  "name": "fullstack-uniframe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k --names api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx apps/api/src/api-server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0 --port 5200",
    "dev:desktop": "npm run dev:desktop:react",
    "dev:desktop:react": "concurrently -k --names desktop-react,desktop -c green,magenta \"vite --config apps/desktop/renderer-react/vite.config.ts --host 127.0.0.1 --port 5201\" \"tsx apps/desktop/wait-and-open.ts 5201\"",
    "dev:desktop:vue": "concurrently -k --names desktop-vue,desktop -c blue,magenta \"vite --config apps/desktop/renderer/vite.config.ts --host 127.0.0.1 --port 5202\" \"tsx apps/desktop/wait-and-open.ts 5202\"",
    "build": "npm run build:web && npm run build:desktop",
    "build:desktop": "npm run build:desktop:react && npm run build:desktop:vue",
    "build:desktop:react": "vite build --config apps/desktop/renderer-react/vite.config.ts",
    "build:desktop:vue": "vite build --config apps/desktop/renderer/vite.config.ts",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "android:add": "cap add android",
    "android:sync": "npm run build:web && cap sync android",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@uniframe/core": "0.1.0",
    "@uniframe/vite": "0.1.0",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "electron": "^42.3.2",
    "tsx": "^4.22.4",
    "vite": "^7.1.5"
  }
}
